@page
@model CreateModel
<h1>Order Form</h1>
<form method="post">
<div class="mt-3 card mb-3 p-3">
 <input type="text" placeholder="Enter Customer Name" class="form-control mb-3"
asp-for="CustomerName" />
 <input type="text" placeholder="Enter Product Name" class="form-control mb-3"
asp-for="ProductName"/>
 <input type="date" class="form-control mb-3" asp-for="ProductDate"/>
 <select class="form-select mb-3" asp-for="Quantity">
<option value="1">1</option>
<option value="2">2</option>
<option value="3">3</option>
</select>
 <input type="number" step="0.01" placeholder="Enter Price" class="form-control mb-3" asp-for="Price"/>
<button type="submit" class="btn btn-primary w-100">Create Order</button>
</div>
</form>