@page
@model EditModel

<h1>Update Product Form</h1>
<form method="post">
    <div class="mt-3 card mb-3 p-3">
        <input type="hidden" asp-for="product.id"/>
        <input type="text" placeholder="Enter Name" class="form-control mb-3" asp-for="product.CustomerName" />
        <input type="text" placeholder="Enter Address" class="form-control mb-3" asp-for="product.ProductName" />
        <input type="date" class="form-control mb-3" asp-for="product.ProductDate" />
        <input type="number" class="form-control mb-3" asp-for="product.Quantity" />
        <input type="number" step="0.01" class="form-control mb-3" asp-for="product.Price" />

        <button type="submit" class="btn btn-primary w-100">Update</button>
    </div>
</form>

