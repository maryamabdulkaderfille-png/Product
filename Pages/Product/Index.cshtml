@page 
@model IndexModel 
<h1 class="mb-3"> Product List</h1> 
<div class=" d-flex justify-content-end mb-3"> 
<a asp-page="create" class="btn btn-success ">Add New Product</a> 
</div> 

<div class="container table-responsive"> 
<table class="table table-bordered table-striped text-center table-responsive" > 
<thead class="table-dark"> 
<tr> 
<th>ID</th> 
<th>Customer Name</th> 
<th>Product Name</th> 
<th>Quantity</th> 
<th>Price</th> 
<th>Action</th> 
</tr> 
</thead> 
<tbody>    
@foreach (var product in Model.products){ 
                <tr> 
                    <td>@product.id</td> 
                    <td>@product.CustomerName</td> 
                    <td>@product.ProductName</td> 
                    <td>@product.Quantity</td> 
                    <td>@product.Price</td> 
                    <td><a asp-page="Edit" asp-route-id="@product.id" class="btn btn-primary btn-sm">Edit</a> 
                        <a asp-page="Delete" asp-route-id="@product.id" class="btn btn-danger btn-sm">Delete</a> 
                    </td> </tr>} 
</tbody></table> 
</div> 